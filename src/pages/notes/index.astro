---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const entries = await getCollection('docs', (entry) =>
  entry.id.startsWith('notes/') && entry.id !== 'notes/index'
);
---

<StarlightPage frontmatter={{ title: '工作筆記', description: '學習與工作相關筆記' }}>
  <ul>
    {entries.map((entry) => (
      <li>
        <a href={`/${entry.id.replace(/\.md$/, '').replace(/\.mdx$/, '')}/`}>
          {entry.data.title}
        </a>
      </li>
    ))}
  </ul>
</StarlightPage>