---
import type { Props } from '@astrojs/starlight/props';
---

<header>
  <div class="header-inner">
    <a href="/" class="site-title">Narcisal Blog</a>
    <nav class="icon-nav">
      <a href="/" title="首頁">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/></svg>
      </a>
      <a href="/diary/diary-2026-05-03" title="日記">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
      </a>
      <a href="/notes/first-note" title="工作筆記">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      </a>
      <a href="/events/first-event" title="紀事">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      </a>
    </nav>
    <div class="right-icons">
      <a href="https://github.com/Narcisal" title="GitHub" target="_blank">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
      </a>
    </div>
  </div>
</header>

<style>
header {
  width: 100%;
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--sl-color-bg);
  border-bottom: 1px solid var(--sl-color-hairline-shade);
  padding: 0;
  height: var(--sl-nav-height);
  display: flex;
  align-items: center;
}
.header-inner {
  width: 100%;
  padding: 0 2rem;
  display: flex;
  align-items: center;
  gap: 2.5rem;
}
.site-title {
  font-weight: 700;
  font-size: 1.1rem;
  color: white;
  text-decoration: none;
  white-space: nowrap;
}
.icon-nav {
  display: flex;
  gap: 2.5rem;
  flex: 1;
  justify-content: center;
}
.icon-nav svg, .right-icons svg {
  width: 22px;
  height: 22px;
}
.icon-nav a, .right-icons a {
  color: rgba(255,255,255,0.6);
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
}
.icon-nav a:hover, .right-icons a:hover {
  color: #fff;
  transform: translateY(-1px);
}
.right-icons {
  display: flex;
  gap: 1.5rem;
  align-items: center;
}
</style>